# ──────────────────────────────────────────────
# Lemon Squeezy Payments
# https://app.lemonsqueezy.com/settings/api
# ──────────────────────────────────────────────

# Your Lemon Squeezy API key (keep secret — server-side only)
LEMONSQUEEZY_API_KEY=live_XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Your store slug (the subdomain: https://SLUG.lemonsqueezy.com)
LEMONSQUEEZY_STORE_SLUG=yourstore

# Your numeric store ID (Settings → Store → Store ID)
LEMONSQUEEZY_STORE_ID=12345

# Variant IDs for each product tier (Products → select product → Variants → ID)
LEMONSQUEEZY_STANDARD_VARIANT_ID=111111
LEMONSQUEEZY_EXPANSION_VARIANT_ID=222222

# Webhook signing secret (Settings → Webhooks → Secret)
# Point the webhook URL at: https://your-domain.com/api/ls-webhook
LEMONSQUEEZY_WEBHOOK_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Your deployed app URL (no trailing slash) — used for checkout redirect
APP_URL=https://your-domain.com

# ──────────────────────────────────────────────
# Client-side (Vite) — prefix with VITE_ to expose to browser
# ──────────────────────────────────────────────

# Set to "true" to show a test-mode banner in the paywall UI
VITE_LS_TEST_MODE=true

# ──────────────────────────────────────────────
# RevenueCat (native Android/iOS billing)
# https://app.revenuecat.com → Project → API Keys → Android
# ──────────────────────────────────────────────

# Android public SDK key (safe to expose — not a secret)
VITE_REVENUECAT_ANDROID_KEY=appl_XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ──────────────────────────────────────────────
# Email
# ──────────────────────────────────────────────
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
